__pycache__/
*.pyc
.venv/
.vscode/
.idea/
.DS_Store
Thumbs.db

# Local Discord exports — large, contain personal usernames, CDN URLs expire in ~24h.
# Keep them out of the repo even with --media (the _Files/ siblings can be huge).
**/data/discord/*
!**/data/discord/.gitkeep

# Preprocessor diagnostic, regenerated on every run.
untagged.log
untagged.json

# Local-only events editor (per-campaign). Manual overrides ARE committed via overrides.json.
events.html
events.bat
